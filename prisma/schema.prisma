generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())

  notifications Notification[]
  pets          Pet[]
}

model Pet {
  id        Int      @id @default(autoincrement())
  name      String
  bio       String?
  image     String?
  createdAt DateTime @default(now())

  owner   User @relation(fields: [ownerId], references: [id])
  ownerId Int

  posts Post[]
  tags  PostTag[]

  likes    Like[]
  comments Comment[]

  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")

  notifications Notification[]
}

model Post {
  id          Int      @id @default(autoincrement())
  image       String
  description String?
  createdAt   DateTime @default(now())
  content     String?
  pet         Pet      @relation(fields: [petId], references: [id])
  petId       Int

  likes         Like[]
  comments      Comment[]
  tags          PostTag[]
  notifications Notification[]
}

model Like {
  id Int @id @default(autoincrement())

  pet   Pet @relation(fields: [petId], references: [id])
  petId Int

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int

  @@unique([petId, postId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  pet   Pet @relation(fields: [petId], references: [id])
  petId Int

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int
}

model Follow {
  id Int @id @default(autoincrement())

  follower   Pet @relation("Following", fields: [followerId], references: [id])
  followerId Int

  following   Pet      @relation("Followers", fields: [followingId], references: [id])
  followingId Int
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model PostTag {
  id Int @id @default(autoincrement())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int

  pet   Pet @relation(fields: [petId], references: [id])
  petId Int

  @@unique([postId, petId])
}

model Notification {
  id        String   @id @default(cuid())
  petId     Int // receptor
  actorId   Int? // quien hizo la acción
  postId    Int? // post relacionado
  type      String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  actor  Pet?  @relation(fields: [actorId], references: [id])
  post   Post? @relation(fields: [postId], references: [id])
  user   User? @relation(fields: [userId], references: [id])
  userId Int?
}
